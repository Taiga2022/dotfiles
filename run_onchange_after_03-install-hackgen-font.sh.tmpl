#!/bin/sh
set -eu

{{ if eq .chezmoi.os "linux" -}}
version="2.10.0"
archive="HackGen_NF_v${version}.zip"
url="https://github.com/yuru7/HackGen/releases/download/v${version}/${archive}"
font_dir="{{ .chezmoi.homeDir }}/.local/share/fonts/HackGen_NF_v${version}"

if [ -f "${font_dir}/HackGenConsoleNF-Regular.ttf" ] &&
   [ -f "${font_dir}/HackGenConsoleNF-Bold.ttf" ] &&
   [ -f "${font_dir}/HackGen35ConsoleNF-Regular.ttf" ] &&
   [ -f "${font_dir}/HackGen35ConsoleNF-Bold.ttf" ]; then
  exit 0
fi

tmp_dir="$(mktemp -d)"
trap 'rm -rf "$tmp_dir"' EXIT HUP INT TERM

curl -fL "$url" -o "${tmp_dir}/${archive}"
unzip -q "${tmp_dir}/${archive}" -d "$tmp_dir"
mkdir -p "$font_dir"
install -m 0644 "${tmp_dir}/HackGen_NF_v${version}/"*.ttf "$font_dir/"
fc-cache -f "$font_dir"
{{ else -}}
# HackGen Nerd Font is installed by Homebrew Cask on macOS.
{{ end -}}
